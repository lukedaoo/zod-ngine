; Engine configuration
:/engine
target_fps                 144            ; target frame rate

; Window configuration
:/window
title                      "Test Engine"
width                      1600
height                     900
transparent                false          ; enable alpha channel
clear_color                0x141A1AFF     ; clear color. Hex format: 0xRRGGBBAA
vsync                      true           ; enable vsync

; Logging configuration
:/log
level                      "debug"        ; trace, debug, info, warning, error, fatal

:/asset.font
primary                    "run-tree/data/fonts/Lora-Regular.ttf"

; Console configuration
:/console
enabled                    true           ; enable in-game console (grave key toggle)
visible_lines              10             ; scrollback rows to show
text_pad_x                 20.0           ; left inset for output/input text
top_pad                    10.0           ; clearance above the first scrollback row
input_box_margin           10.0           ; input box inset FRom left/right panel edges
input_box_stroke           2.0            ; input box border thickness in px
input_right_pad            4.0            ; right clearance before input text wraps/scrolls
font_size                  32.0           ; console text size in px, like a text editor's font size
input_gap                  8.0            ; vertical gap between last scrollback row and input box
output_text_color          0x808080FF     ; scrollback line color. Hex format: 0xRRGGBBAA
input_text_color           0xFFFFFFFF     ; input line + cursor color. Hex format: 0xRRGGBBAA
input_box_color            0xFF223366     ; input box border color. Hex format: 0xRRGGBBAA
input_box_background_color 0x00000080     ; input box fill color. Hex format: 0xRRGGBBAA
background_color           0x114455D9     ; panel background color. Hex format: 0xRRGGBBAA
