{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "nob: build",
            "type": "shell",
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: run",
            "type": "shell",
            "args": ["run"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: debug",
            "type": "shell",
            "args": ["run", "debug"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: release",
            "type": "shell",
            "args": ["run", "release"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: test",
            "type": "shell",
            "args": ["test"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "test",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: test-build",
            "type": "shell",
            "args": ["test-build"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "test",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "nob: test-asan",
            "type": "shell",
            "args": ["test-asan"],
            "windows": { "command": "${workspaceFolder}/nob.exe" },
            "linux":   { "command": "${workspaceFolder}/nob" },
            "group": "test",
            "problemMatcher": ["$gcc"]
        }
    ]
}
